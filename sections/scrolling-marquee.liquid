{% comment %}
  Presha Trends — Scrolling Marquee
  Dark navy ticker band below hero + category pills.
  CSS drives the animation — no external dependency.
  JS handles smooth slow-down on hover via Web Animations API.
{% endcomment %}

{%- assign items = "PRESHA VERIFIED AUTHENTICITY|WORLDWIDE SHIPPING|TRUSTED GLOBAL RESALE PLATFORM|LUXURY RESTOCK|EXCLUSIVE DROPS|AUTHENTIC SNEAKERS" | split: "|" -%}

{%- comment -%}
  Keyframes defined inline so they are guaranteed available in-document
  before the element renders — avoids any async stylesheet timing issue.
{%- endcomment -%}
<style>
  @keyframes pt-mq-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>

<div class="pt-mq" id="pt-mq-{{ section.id }}" aria-hidden="true">
  <div class="pt-mq__inner">
    {%- for pass in (1..2) -%}
      <div class="pt-mq__strip">
        {%- for item in items -%}
          <span class="pt-mq__text">{{ item }}</span><span class="pt-mq__dot" aria-hidden="true">•</span>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  /* overflow: hidden on both axes — valid combination, clips the scrolling inner strip */
  .pt-mq {
    background-color: #111929;
    overflow: hidden;
    width: 100%;
    display: block;
  }

  /* width: max-content is critical — makes translateX(-50%) = exactly one strip width */
  .pt-mq__inner {
    display: flex;
    align-items: center;
    width: max-content;
    padding-block: 15px;
    animation: pt-mq-scroll 32s linear infinite;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .pt-mq__inner { animation: none !important; }
  }

  .pt-mq__strip {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .pt-mq__text {
    font-family: 'Jost', var(--font-body--family, sans-serif);
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    white-space: nowrap;
    padding-inline: 1.25rem;
  }

  .pt-mq__dot {
    font-size: 0.4rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1;
    flex-shrink: 0;
    padding-inline: 0.25rem;
  }
{% endstylesheet %}

<script>
(function () {
  var el = document.getElementById('pt-mq-{{ section.id }}');
  if (!el) return;

  var inner = el.querySelector('.pt-mq__inner');
  if (!inner) return;

  /* Smooth slow-down on hover via Web Animations API playbackRate */
  var raf        = null;
  var currentRate = 1;
  var SLOW_RATE  = 0.12;
  var EASE_MS    = 500;

  function lerpRate(from, to, startTime) {
    cancelAnimationFrame(raf);
    function tick(now) {
      var t      = Math.min((now - startTime) / EASE_MS, 1);
      var eased  = t * t * (3 - 2 * t);   /* smoothstep */
      currentRate = from + (to - from) * eased;
      var anim = inner.getAnimations()[0];
      if (anim) anim.updatePlaybackRate(currentRate);
      if (t < 1) raf = requestAnimationFrame(tick);
    }
    raf = requestAnimationFrame(tick);
  }

  el.addEventListener('pointerenter', function () {
    lerpRate(currentRate, SLOW_RATE, performance.now());
  });

  el.addEventListener('pointerleave', function () {
    lerpRate(currentRate, 1, performance.now());
  });
})();
</script>

{% schema %}
{
  "name": "Scrolling Marquee",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "Scrolling Marquee"
    }
  ]
}
{% endschema %}
