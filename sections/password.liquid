{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ shop.name }} — Coming Soon</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />

  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

  <style>
    /* ─── Reset & Base ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --burgundy:       #8B1020;
      --burgundy-dark:  #6B0F1A;
      --burgundy-deep:  #3D060F;
      --cream:          #F4F0EB;
      --offwhite:       #EFEFEF;
      --charcoal:       #1A1A1A;
      --mid-grey:       #888888;
      --light-grey:     #CCCCCC;
      --white:          #FFFFFF;
      --font-serif:     'Cormorant Garamond', Georgia, serif;
      --font-sans:      'Jost', sans-serif;
    }

    html, body {
      height: 100%;
      overflow: hidden;
    }

    body {
      font-family: var(--font-sans);
      background: var(--offwhite);
      color: var(--charcoal);
    }

    /* ─── Announcement Bar ──────────────────────────────────────── */
    .announcement-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--burgundy-dark);
      color: var(--white);
      padding: 9px 0;
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.18em;
      overflow: hidden;
    }

    /* Desktop: centred static text */
    .ann-static {
      display: flex;
      justify-content: center;
      align-items: center;
      white-space: nowrap;
      padding: 0 20px;
    }

    .ann-static span {
      opacity: 0.5;
      margin: 0 10px;
      font-size: 9px;
    }

    /* Mobile marquee wrapper — hidden on desktop */
    .ann-marquee { display: none; overflow: hidden; }

    .ann-marquee-track {
      display: flex;
      white-space: nowrap;
      width: max-content;
      animation: ann-scroll 18s linear infinite;
    }

    .ann-marquee-track .sep {
      opacity: 0.45;
      margin: 0 14px;
      font-size: 9px;
    }

    @keyframes ann-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    @media (max-width: 768px) {
      .ann-static  { display: none; }
      .ann-marquee { display: block; }
    }

    /* ─── Main Layout ───────────────────────────────────────────── */
    .layout {
      display: grid;
      grid-template-columns: 55% 45%;
      height: 100vh;
      /* No padding-top here — right panel must be flush with announcement bar */
    }

    /* ─── Left Panel ────────────────────────────────────────────── */
    .panel-left {
      background: var(--offwhite);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 20px 64px;
      padding-top: calc(37px + 20px);
      padding-bottom: calc(36px + 10px);
      overflow: hidden;
      position: relative;
      height: 100vh;
      box-sizing: border-box;
    }

    /* ─── Groups ────────────────────────────────────────────────── */
    .group {
      display: flex;
      flex-direction: column;
    }

    /* Group 1 — Brand: logo centred, extra space below to separate from headline */
    .group-brand {
      align-items: flex-end;
      gap: 4px;
      padding-bottom: 16px;
    }

    /* Group 2 — Message: headline + body close together */
    .group-message {
      gap: 10px;
    }

    /* Group 3 — CTA: form + micro copy tight */
    .group-cta {
      gap: 8px;
    }

    /* Group 4 — Secondary: password link + trust badges */
    .group-secondary {
      gap: 10px;
    }

    /* subtle grain overlay */
    .panel-left::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      opacity: 0.4;
    }

    /* ─── Logo Mark ─────────────────────────────────────────────── */
    .logo-mark {
      display: flex;
      justify-content: center;
    }

    .logo-mark img {
      height: 75px;
      width: auto;
      object-fit: contain;
    }

    /* ─── Wordmark ──────────────────────────────────────────────── */
    .wordmark {
      text-align: center;
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 500;
      color: var(--burgundy);
      letter-spacing: 0.04em;
      margin-bottom: 0;
    }

    /* ─── Headline ──────────────────────────────────────────────── */
    .headline {
      font-family: var(--font-serif);
      font-size: clamp(46px, 6.0vw, 55px);
      font-weight: 400;
      line-height: 1.08;
      color: var(--charcoal);
      margin-bottom: 0;
    }

    .headline-line {
      display: block;
      opacity: 1;
      transform: translateY(0);
      transition: none;
    }

    /* GSAP sets these before animating — only applied when JS runs */
    .headline-line.gsap-init {
      opacity: 0;
      transform: translateY(40px);
    }

    .headline-line.italic {
      font-style: italic;
      font-weight: 450;
      color: var(--burgundy);
    }

    /* ─── Body Text ─────────────────────────────────────────────── */
    .body-text {
      font-family: var(--font-sans);
      font-size: 13.5px;
      font-weight: 300;
      line-height: 1.65;
      color: #555;
      margin-bottom: 0;
      max-width: 380px;
    }

    /* ─── Trust Strip ───────────────────────────────────────────── */
    .trust-strip {
      font-family: var(--font-sans);
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--mid-grey);
      margin-bottom: 0;
      white-space: nowrap;
    }

    .trust-strip span { margin: 0 5px; opacity: 0.5; }

    /* ─── Email Form ────────────────────────────────────────────── */
    .email-form {
      display: flex;
      gap: 0;
      margin-bottom: 0;
      max-width: 440px;
    }

    .email-form input[type="email"] {
      flex: 1;
      padding: 14px 18px;
      border: 1.5px solid #d8d0c8;
      border-right: none;
      border-radius: 3px 0 0 3px;
      background: var(--white);
      font-family: var(--font-sans);
      font-size: 13.5px;
      font-weight: 300;
      color: var(--charcoal);
      outline: none;
      transition: border-color 0.3s;
    }

    .email-form input[type="email"]::placeholder { color: #aaa; }
    .email-form input[type="email"]:focus { border-color: var(--burgundy); }

    .email-form button {
      padding: 14px 24px;
      background: var(--burgundy);
      color: var(--white);
      border: 1.5px solid var(--burgundy);
      border-radius: 0 3px 3px 0;
      font-family: var(--font-sans);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.3s, transform 0.15s;
    }

    .email-form button:hover {
      background: var(--burgundy-dark);
      transform: scale(1.02);
    }

    /* ─── Micro Copy ────────────────────────────────────────────── */
    .micro-copy {
      font-size: 11.5px;
      color: var(--mid-grey);
      font-weight: 300;
      margin-bottom: 0;
    }

    .micro-copy a { color: var(--burgundy); text-decoration: none; }

    /* ─── Password Link ─────────────────────────────────────────── */
    .password-links {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 12.5px;
      color: var(--mid-grey);
      margin-bottom: 0;
    }

    .password-links a {
      color: var(--charcoal);
      text-decoration: underline;
      text-underline-offset: 3px;
      font-size: 12.5px;
      cursor: pointer;
    }

    .password-links .divider { opacity: 0.4; }

    /* ─── Trust Badges ──────────────────────────────────────────── */
    .trust-badges {
      display: flex;
      gap: 20px;
      font-size: 11px;
      color: #888;
      font-weight: 400;
      letter-spacing: 0.04em;
      margin-bottom: 0;
    }

    .trust-badge {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    /* ─── Password Form (hidden modal) ─────────────────────────── */
    .password-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.75);
      z-index: 200;
      align-items: center;
      justify-content: center;
    }

    .password-modal.active { display: flex; }

    .password-modal-inner {
      background: var(--white);
      padding: 48px 40px;
      max-width: 400px;
      width: 90%;
      border-radius: 2px;
    }

    .password-modal-inner h3 {
      font-family: var(--font-serif);
      font-size: 26px;
      font-weight: 400;
      margin-bottom: 8px;
      color: var(--charcoal);
    }

    .password-modal-inner p {
      font-size: 13px;
      color: #888;
      margin-bottom: 24px;
    }

    .password-modal-inner input[type="password"] {
      width: 100%;
      padding: 13px 16px;
      border: 1.5px solid #d8d0c8;
      border-radius: 3px;
      font-family: var(--font-sans);
      font-size: 14px;
      outline: none;
      margin-bottom: 12px;
      transition: border-color 0.3s;
    }

    .password-modal-inner input[type="password"]:focus {
      border-color: var(--burgundy);
    }

    .password-modal-inner button {
      width: 100%;
      padding: 14px;
      background: var(--burgundy);
      color: var(--white);
      border: none;
      border-radius: 3px;
      font-family: var(--font-sans);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
    }

    .modal-close {
      position: absolute;
      top: 16px;
      right: 20px;
      font-size: 22px;
      cursor: pointer;
      color: #999;
      line-height: 1;
    }

    /* ─── Right Panel ───────────────────────────────────────────── */
    .panel-right {
      position: relative;
      overflow: hidden;
    }

    .panel-right img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      transform: scale(1.06);
    }

    /* warm overlay on photo */
    .panel-right::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        160deg,
        rgba(139,16,32,0.08) 0%,
        rgba(0,0,0,0.15) 100%
      );
      pointer-events: none;
    }

    /* ─── Ticker Bar ────────────────────────────────────────────── */
    .ticker-wrap {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--charcoal);
      padding: 9px 0;
      overflow: hidden;
      z-index: 50;
    }

    .ticker-track {
      display: flex;
      white-space: nowrap;
      animation: ticker-scroll 28s linear infinite;
      width: max-content;
    }

    .ticker-item {
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
      padding: 0 28px;
    }

    .ticker-dot {
      color: var(--burgundy);
      margin: 0 4px;
      font-size: 10px;
    }

    @keyframes ticker-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ─── Footer ────────────────────────────────────────────────── */
    .footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 8px;
      border-top: 1px solid rgba(0,0,0,0.08);
    }

    .footer-copy {
      font-size: 11px;
      color: var(--mid-grey);
      font-weight: 300;
      line-height: 1.5;
    }

    .footer-ig {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--mid-grey);
      text-decoration: none;
      transition: color 0.3s;
      flex-shrink: 0;
      margin-left: 16px;
    }

    .footer-ig:hover { color: var(--burgundy); }

    /* ─── Success Message ───────────────────────────────────────── */
    .success-msg {
      display: none;
      font-size: 12px;
      color: #2d7a3a;
      font-weight: 400;
      letter-spacing: 0.04em;
      margin-top: 8px;
      padding: 10px 14px;
      background: rgba(45,122,58,0.08);
      border-radius: 3px;
      border-left: 3px solid #2d7a3a;
    }

    /* ════════════════════════════════════════════════════════════
       RESPONSIVE — all breakpoints
       ════════════════════════════════════════════════════════════

       Breakpoints used:
         ≤ 1280px  — small laptop
         ≤ 1024px  — large tablet landscape / small laptop
         ≤  900px  — tablet landscape
         ≤  768px  — tablet portrait + mobile (stacked layout)
         ≤  480px  — small mobile
         landscape + max-height 500px — mobile landscape
    ════════════════════════════════════════════════════════════ */

    /* ── Small laptop (1024–1280px) ─────────────────────────── */
    @media (max-width: 1280px) {
      .panel-left {
        padding-left: 48px;
        padding-right: 48px;
      }
      .headline { font-size: clamp(40px, 5.8vw, 58px); }
      .wordmark  { font-size: 26px; }
      .logo-mark img { height: 54px; }
    }

    /* ── Large tablet landscape / small laptop (900–1024px) ── */
    @media (max-width: 1024px) {
      .layout { grid-template-columns: 58% 42%; }

      .panel-left {
        padding-left: 36px;
        padding-right: 36px;
      }

      .headline  { font-size: clamp(36px, 5.2vw, 52px); }
      .wordmark  { font-size: 24px; }
      .logo-mark img { height: 50px; }
      .body-text { font-size: 13px; }

      .email-form input[type="email"],
      .email-form button { padding: 12px 16px; font-size: 11.5px; }
    }

    /* ── Tablet landscape (768–900px) ───────────────────────── */
    @media (max-width: 900px) {
      .layout { grid-template-columns: 60% 40%; }

      .panel-left {
        padding-left: 28px;
        padding-right: 28px;
      }

      .headline  { font-size: clamp(30px, 4.5vw, 46px); }
      .wordmark  { font-size: 22px; }
      .logo-mark img { height: 46px; }
      .trust-strip { font-size: 8px; letter-spacing: 0.08em; }

      /* Switch announcement bar to marquee on tablet too */
      .ann-static  { display: none; }
      .ann-marquee { display: block; }
    }

    /* ── Tablet portrait + mobile — STACKED LAYOUT (≤ 768px) ─ */
    @media (max-width: 768px) {
      html, body { overflow-y: auto; overflow-x: hidden; }

      .layout {
        display: flex;
        flex-direction: column;
        height: auto;
        min-height: 100vh;
      }

      /* Photo FIRST on mobile */
      .panel-right {
        width: 100%;
        height: 55vw;
        min-height: 240px;
        max-height: 380px;
        order: 1;
        flex-shrink: 0;
      }

      /* Content BELOW photo — all centred */
      .panel-left {
        width: 100%;
        height: auto;
        min-height: unset;
        order: 2;
        justify-content: flex-start;
        align-items: center;
        text-align: center;
        gap: 20px;
        padding: 28px 24px;
        padding-bottom: calc(36px + 28px);
      }

      .group { width: 100%; align-items: center; }
      .group-brand   { gap: 4px; }
      .group-message { gap: 10px; }
      .group-cta     { gap: 8px; align-items: center; }
      .group-secondary { gap: 10px; align-items: center; }

      .logo-mark         { justify-content: center; }
      .logo-mark img     { height: 56px; }
      .wordmark          { font-size: 26px; text-align: center; }
      .headline          { font-size: 46px; text-align: center; }
      .body-text         { font-size: 14px; max-width: 100%; text-align: center; }
      .micro-copy        { font-size: 11px; text-align: center; }
      .password-links    { font-size: 12px; justify-content: center; }
      .footer-copy       { font-size: 10.5px; text-align: left; }
      .footer-ig         { margin-left: 0; flex-shrink: 0; }

      /* Email form — full width, centred */
      .email-form {
        max-width: 100%;
        width: 100%;
        justify-content: center;
      }

      /* Trust strip: wrap and centre */
      .trust-strip {
        white-space: normal;
        text-align: center;
      }

      /* Trust badges: centre */
      .trust-badges { justify-content: center; }

      /* Footer: full width, left-right spread on mobile */
      .footer {
        width: 100%;
        flex-wrap: nowrap;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
        padding-top: 14px;
        margin-top: 4px;
        text-align: left;
      }

      /* Announcement bar: marquee */
      .ann-static  { display: none; }
      .ann-marquee { display: block; }
    }

    /* ── Small mobile (≤ 480px) ─────────────────────────────── */
    @media (max-width: 480px) {
      .panel-right {
        height: 60vw;
        min-height: 200px;
      }

      .panel-left {
        padding: 22px 18px;
        padding-bottom: calc(36px + 22px);
        gap: 16px;
        align-items: center;
        text-align: center;
      }

      .group { width: 100%; align-items: center; }

      .logo-mark img  { height: 48px; }
      .wordmark       { font-size: 22px; }
      .headline       { font-size: 38px; text-align: center; }
      .body-text      { font-size: 13px; text-align: center; }

      /* Stack email form vertically on very small screens */
      .email-form {
        flex-direction: column;
        gap: 8px;
      }

      .email-form input[type="email"] {
        border-right: 1.5px solid #d8d0c8;
        border-radius: 3px;
        padding: 13px 16px;
      }

      .email-form button {
        border-radius: 3px;
        padding: 13px 16px;
        text-align: center;
      }

      .password-links { font-size: 11.5px; gap: 10px; }
      .trust-badges   { gap: 12px; font-size: 10.5px; }
      .footer-copy    { font-size: 10px; }

      .ticker-item    { font-size: 9px; padding: 0 18px; }
    }

    /* ── Mobile landscape (short screens in landscape) ──────── */
    @media (max-height: 500px) and (orientation: landscape) {
      html, body { overflow-y: auto; }

      .layout {
        display: grid;
        grid-template-columns: 55% 45%;
        height: auto;
        min-height: 100vh;
      }

      .panel-left {
        height: auto;
        min-height: 100vh;
        justify-content: flex-start;
        gap: 10px;
        padding: 20px 28px;
        padding-top: calc(37px + 16px);
        padding-bottom: calc(36px + 16px);
        overflow-y: auto;
        order: unset;
      }

      .panel-right {
        height: auto;
        min-height: 100vh;
        order: unset;
      }

      .logo-mark img { height: 40px; }
      .wordmark      { font-size: 20px; }
      .headline      { font-size: 32px; }
      .body-text     { font-size: 12.5px; line-height: 1.5; }
      .trust-strip   { font-size: 8px; }
      .email-form input[type="email"],
      .email-form button { padding: 10px 14px; font-size: 11px; }
      .micro-copy    { font-size: 10.5px; }
      .trust-badges  { font-size: 10px; gap: 12px; }

      .ann-static  { display: none; }
      .ann-marquee { display: block; }
    }
  </style>
</head>
<body>

  <!-- ── Announcement Bar ─────────────────────────────────────── -->
  <div class="announcement-bar" id="annBar">

    <!-- Desktop: static centred text -->
    <div class="ann-static">
      Presha Verified Authenticity
      <span>|</span>
      Worldwide Shipping
      <span>|</span>
      Dubai Based
    </div>

    <!-- Mobile: scrolling marquee -->
    <div class="ann-marquee">
      <div class="ann-marquee-track">
        Presha Verified Authenticity <span class="sep">✦</span>
        Worldwide Shipping <span class="sep">✦</span>
        Dubai Based <span class="sep">✦</span>
        Presha Verified Authenticity <span class="sep">✦</span>
        Worldwide Shipping <span class="sep">✦</span>
        Dubai Based <span class="sep">✦</span>
      </div>
    </div>

  </div>

  <!-- ── Main Layout ──────────────────────────────────────────── -->
  <div class="layout">

    <!-- LEFT PANEL -->
    <div class="panel-left" id="panelLeft">

      <!-- ── GROUP 1: Brand ──────────────────────────────── -->
      <div class="group group-brand" id="logoMark">
        <div class="logo-mark">
          <img
            src="{{ 'logo-full.png' | asset_url }}"
            alt="Presha Trends"
          />
        </div>
      </div>

      <!-- ── GROUP 2: Message ────────────────────────────── -->
      <div class="group group-message" id="groupMessage">
        <h1 class="headline">
          <span class="headline-line" id="hl1">The Dubai Edit</span>
          <span class="headline-line italic" id="hl2">is Coming</span>
        </h1>
        <p class="body-text" id="bodyText">
          Curated luxury streetwear and rare sneakers,<br>authenticated in Dubai.
        </p>
      </div>

      <!-- ── GROUP 3: CTA ────────────────────────────────── -->
      <div class="group group-cta" id="groupCta">
        <!-- Trust Strip — commented out, re-enable by removing the comment tags
        <div class="trust-strip" id="trustStrip">
          PRESHA VERIFIED <span>•</span> WORLDWIDE SHIPPING <span>•</span> PREMIUM SUPPORT
        </div>
        -->
        {% form 'customer' %}
          <input type="hidden" name="contact[tags]" value="newsletter,prelaunch" />
          <div class="email-form" id="emailForm">
            <input
              type="email"
              name="contact[email]"
              placeholder="Enter your email"
              required
              autocomplete="email"
            />
            <button type="submit">Get Notified</button>
          </div>
          <p class="micro-copy" id="microCopy">
            Drops, rare finds, and curated collections — delivered first. <a href="#">No spam.</a>
          </p>
        {% endform %}

        {% if form.posted_successfully? %}
          <div class="success-msg" id="successMsg" style="display:block;">
            ✓ You're on the list. We'll be in touch before anyone else.
          </div>
        {% endif %}
      </div>

      <!-- ── GROUP 4: Secondary ──────────────────────────── -->
      <div class="group group-secondary" id="groupSecondary">
        <div class="password-links" id="passLinks">
          <a onclick="openPasswordModal()" style="cursor:pointer;">
            Enter using password
          </a>
          <span class="divider">|</span>
          <a href="{{ routes.root_url }}admin" target="_self">Store owner? Log in</a>
        </div>
        <div class="trust-badges" id="trustBadges">
          <div class="trust-badge">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="9" stroke="#888" stroke-width="1.5"/>
              <path d="M6 10l3 3 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Verified
          </div>
          <div class="trust-badge">
            <svg width="11" height="13" viewBox="0 0 16 20" fill="none">
              <rect x="1" y="8" width="14" height="11" rx="2" stroke="#888" stroke-width="1.5"/>
              <path d="M4 8V5a4 4 0 018 0v3" stroke="#888" stroke-width="1.5"/>
            </svg>
            Secure
          </div>
          <div class="trust-badge">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="9" stroke="#888" stroke-width="1.5"/>
              <ellipse cx="10" cy="10" rx="4" ry="9" stroke="#888" stroke-width="1.5"/>
              <line x1="1" y1="10" x2="19" y2="10" stroke="#888" stroke-width="1.5"/>
            </svg>
            Worldwide
          </div>
        </div>
      </div>

      <!-- ── GROUP 5: Footer ─────────────────────────────── -->
      <div class="footer" id="footer">
        <span class="footer-copy">
          © {{ 'now' | date: '%Y' }} Presha Trends &mdash; powered by hollowkraft collective
        </span>
        <a href="https://instagram.com/preshatrends" class="footer-ig" target="_blank" rel="noopener" aria-label="Presha Trends on Instagram">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
      </div>

    </div>

    <!-- RIGHT PANEL — editorial boutique photo -->
    <div class="panel-right" id="panelRight">
      <!--
        INSTRUCTIONS: Replace the src below with your own boutique/product image.
        Upload the image to Shopify Admin > Content > Files, then use its CDN URL.
        Ideal size: 1400×1800px, portrait orientation.
        Example: src="{{ 'your-boutique-hero.jpg' | asset_url }}"
      -->
      <img
        src="{{ 'luxury-picture.jpg' | asset_url }}"
        alt="Presha Trends luxury boutique"
        loading="eager"
      />
    </div>

  </div>

  <!-- ── Scrolling Ticker ──────────────────────────────────────── -->
  <div class="ticker-wrap" id="ticker">
    <div class="ticker-track">
      <!-- Duplicated for seamless loop -->
      <span class="ticker-item">COMING SOON</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">THE DUBAI EDIT</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">AUTHENTICATED LUXURY</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">RARE SNEAKERS</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">PRESHA VERIFIED</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">WORLDWIDE SHIPPING</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">DUBAI BASED</span><span class="ticker-dot">✦</span>
      <!-- duplicate set -->
      <span class="ticker-item">COMING SOON</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">THE DUBAI EDIT</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">AUTHENTICATED LUXURY</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">RARE SNEAKERS</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">PRESHA VERIFIED</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">WORLDWIDE SHIPPING</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">DUBAI BASED</span><span class="ticker-dot">✦</span>
    </div>
  </div>

  <!-- ── Password Modal ────────────────────────────────────────── -->
  <div class="password-modal" id="passwordModal">
    <div class="password-modal-inner" style="position:relative;">
      <span class="modal-close" onclick="closePasswordModal()">&times;</span>

      <h3>Enter Password</h3>
      <p>This store is password protected. Enter the password to access it.</p>

      {% form 'storefront_password' %}
        <input
          type="password"
          name="password"
          id="passwordInput"
          placeholder="Store password"
          autocomplete="current-password"
          autofocus
        />

        {% if form.errors %}
          <p style="color:#8B1020; font-size:12px; margin-top:-6px; margin-bottom:14px; letter-spacing:0.02em;">
            ✕ &nbsp;Incorrect password. Please try again.
          </p>
        {% endif %}

        <button type="submit">Enter Store</button>
      {% endform %}

      <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid #eee; text-align:center;">
        <a
          href="{{ routes.root_url }}admin"
          style="font-size:11.5px; color:#888; text-decoration:none; letter-spacing:0.05em; font-family:'Jost',sans-serif;"
        >
          Store owner? <span style="color:#8B1020; text-decoration:underline; text-underline-offset:3px;">Log in to admin</span>
        </a>
      </div>
    </div>
  </div>

  <!-- ── GSAP Entrance Animations ─────────────────────────────── -->
  <script>
    // ── Modal controls ───────────────────────────────────────────
    function openPasswordModal() {
      document.getElementById('passwordModal').classList.add('active');
      setTimeout(function() {
        var input = document.getElementById('passwordInput');
        if (input) input.focus();
      }, 100);
    }

    function closePasswordModal() {
      document.getElementById('passwordModal').classList.remove('active');
    }

    // Close on backdrop click
    document.getElementById('passwordModal').addEventListener('click', function(e) {
      if (e.target === this) closePasswordModal();
    });

    // Close on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closePasswordModal();
    });

    // Auto-open modal if Shopify returned a password error
    {% if form.errors %}
      document.addEventListener('DOMContentLoaded', function() {
        openPasswordModal();
      });
    {% endif %}

    document.addEventListener('DOMContentLoaded', function () {

      // ── Set initial hidden states via GSAP (not CSS) ─────────
      gsap.set('#annBar',        { opacity: 0 });
      gsap.set('#panelRight',    { opacity: 0 });
      gsap.set('#panelRight img',{ scale: 1.06 });
      gsap.set('#logoMark',      { opacity: 0, y: -12 });
      gsap.set('#hl1',           { opacity: 0, y: 40 });
      gsap.set('#hl2',           { opacity: 0, y: 40 });
      gsap.set('#bodyText',      { opacity: 0, y: 16 });
      gsap.set('#groupCta',      { opacity: 0, y: 20 });
      gsap.set('#groupSecondary',{ opacity: 0 });
      gsap.set('#footer',        { opacity: 0 });
      gsap.set('#ticker',        { opacity: 0 });

      // ── Master entrance timeline — animates by group ─────────
      var tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

      // 1. Announcement bar
      tl.to('#annBar', { opacity: 1, duration: 0.6, ease: 'power2.out' })

      // 2. Right photo panel
      .to('#panelRight',      { opacity: 1, duration: 1.1 }, 0.2)
      .to('#panelRight img',  { scale: 1, duration: 1.8, ease: 'power2.out' }, 0.2)

      // 3. Group 1 — Brand (logo)
      .to('#logoMark', { opacity: 1, y: 0, duration: 0.7, ease: 'back.out(1.4)' }, 0.4)

      // 4. Group 2 — Message (headline lines stagger, then body)
      .to('#hl1',      { opacity: 1, y: 0, duration: 0.7 }, 0.7)
      .to('#hl2',      { opacity: 1, y: 0, duration: 0.7 }, 0.85)
      .to('#bodyText', { opacity: 1, y: 0, duration: 0.55 }, 1.05)

      // 5. Group 3 — CTA (whole group fades up together)
      .to('#groupCta', { opacity: 1, y: 0, duration: 0.55 }, 1.2)

      // 6. Group 4 — Secondary
      .to('#groupSecondary', { opacity: 1, duration: 0.5 }, 1.4)

      // 7. Group 5 — Footer
      .to('#footer', { opacity: 1, duration: 0.5 }, 1.55)

      // 8. Ticker bar
      .to('#ticker', { opacity: 1, duration: 0.6, ease: 'power2.out' }, 1.3);

      // ── Hover: magnetic button effect ───────────────────────
      var btn = document.querySelector('.email-form button');
      if (btn) {
        btn.addEventListener('mousemove', function(e) {
          var rect = btn.getBoundingClientRect();
          var x = e.clientX - rect.left - rect.width / 2;
          var y = e.clientY - rect.top - rect.height / 2;
          gsap.to(btn, { x: x * 0.18, y: y * 0.18, duration: 0.3, ease: 'power2.out' });
        });
        btn.addEventListener('mouseleave', function() {
          gsap.to(btn, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.4)' });
        });
      }

      // ── Auto-show success message if form just submitted ────
      var successMsg = document.getElementById('successMsg');
      if (successMsg && successMsg.style.display === 'block') {
        gsap.fromTo(successMsg,
          { opacity: 0, y: 8 },
          { opacity: 1, y: 0, duration: 0.5, delay: 2.2, ease: 'power2.out' }
        );
      }

    });
  </script>

</body>
</html>
