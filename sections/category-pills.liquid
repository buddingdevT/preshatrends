{% comment %}
  Presha Trends — Category Pills
  Dark semi-transparent cards — thumbnail LEFT, "SHOP BY" label + category name RIGHT.
  Horizontal row below the hero slideshow (no overlap).
  Reference: madkicks.com category pills layout.
{% endcomment %}

<div class="category-pills-section" id="CategoryPills-{{ section.id }}">
  <div class="category-pills-track page-width">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '/collections/all' }}"
        class="category-pill"
        {{ block.shopify_attributes }}
      >
        <div class="category-pill__image-wrap">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 200
              | image_tag:
                class: 'category-pill__image',
                loading: 'eager',
                widths: '80, 120, 200',
                alt: block.settings.title
            }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'category-pill__image category-pill__image--placeholder' }}
          {%- endif -%}
        </div>
        <div class="category-pill__text">
          <span class="category-pill__label">SHOP BY</span>
          <span class="category-pill__title">{{ block.settings.title }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  /* ============================================================
     Presha Trends — Category Pills (madkicks-style)
     Dark cards, thumbnail LEFT, SHOP BY label + name RIGHT
  ============================================================ */

  .category-pills-section {
    position: relative;
    z-index: 10;
    padding-block-start: 0;
    padding-block-end: 32px;
    background: transparent;
  }

  .category-pills-section .page-width {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-block: 12px; /* room for hover lift */
    -webkit-overflow-scrolling: touch;
  }

  .category-pills-section .page-width::-webkit-scrollbar {
    display: none;
  }

  /* Individual pill card — dark glass style */
  .category-pill {
    flex: 1 1 0;
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(18, 18, 18, 0.84);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    padding: 14px 18px 14px 14px;
    text-decoration: none;
    color: inherit;
    min-width: 190px;
    transition: background 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
    will-change: transform;
  }

  .category-pill:hover {
    background: rgba(32, 32, 32, 0.94);
    border-color: rgba(255, 255, 255, 0.14);
    transform: translateY(-3px);
  }

  /* Thumbnail — LEFT side */
  .category-pill__image-wrap {
    width: 76px;
    height: 76px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.06);
  }

  .category-pill__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .category-pill__image--placeholder {
    padding: 12px;
    opacity: 0.25;
    filter: invert(1);
  }

  /* Text block — RIGHT side */
  .category-pill__text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
    min-width: 0;
  }

  .category-pill__label {
    font-family: 'Jost', sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1;
    white-space: nowrap;
  }

  .category-pill__title {
    font-family: 'Jost', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Mobile — horizontal scroll with peek of next card */
  @media screen and (max-width: 749px) {
    .category-pills-section {
      padding-block-end: 24px;
    }

    .category-pills-section .page-width {
      padding-inline: var(--page-margin);
      max-width: none;
      width: 100%;
    }

    .category-pill {
      flex: 0 0 auto;
      min-width: 168px;
      max-width: 200px;
      padding: 12px 14px 12px 12px;
      gap: 10px;
    }

    .category-pill__image-wrap {
      width: 62px;
      height: 62px;
    }

    .category-pill__title {
      font-size: 0.875rem;
    }
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    var pills = document.querySelectorAll('#CategoryPills-{{ section.id }} .category-pill');
    if (!pills.length) return;

    gsap.fromTo(
      pills,
      { y: 24, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.65,
        stagger: 0.08,
        ease: 'power3.out',
        clearProps: 'transform,opacity',
        scrollTrigger: {
          trigger: '#CategoryPills-{{ section.id }}',
          start: 'top 95%',
          once: true
        }
      }
    );
  });
</script>

{% schema %}
{
  "name": "Category Pills",
  "tag": "section",
  "class": "category-pills-outer",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "pill",
      "name": "Category Pill",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Thumbnail image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Pills",
      "blocks": [
        { "type": "pill", "settings": { "title": "Trending Now" } },
        { "type": "pill", "settings": { "title": "Pokemon Collectibles" } },
        { "type": "pill", "settings": { "title": "Chrome Hearts" } },
        { "type": "pill", "settings": { "title": "Loewe x On" } }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
