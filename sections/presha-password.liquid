  <div style="max-width:720px; width:100%; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;">
    <div style="background:#6d001a; color:#fff; padding:10px 16px; border-radius:12px; text-align:center; font-size:12px;">
      Presha Verified Authenticity | Worldwide Shipping | Dubai Based
    </div>

    <h1 style="margin:24px 0 8px; font-size:36px; line-height:1.1;">Presha Trends Password Page</h1>
    <p style="margin:0 0 24px; color:rgba(0,0,0,.65);">
      If you can see this, the custom section is working. Next we’ll add the full design.
    </p>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:18px;">
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="presha-password-page">
        <input type="hidden" name="contact[accepts_marketing]" value="true">
        <input type="email" name="contact[email]" required placeholder="Enter your email"
          style="padding:12px 14px; border-radius:12px; border:1px solid rgba(0,0,0,.15); min-width:260px;">
        <button type="submit"
          style="padding:12px 16px; border-radius:12px; border:none; background:#6d001a; color:#fff; cursor:pointer;">
          Get Notified
        </button>
      {% endform %}
    </div>

    <div style="margin-top:10px;">
      {% form 'storefront_password' %}
        <input type="password" name="password" required placeholder="Password"
          style="padding:12px 14px; border-radius:12px; border:1px solid rgba(0,0,0,.15); min-width:260px;">
        <button type="submit"
          style="padding:12px 16px; border-radius:12px; border:none; background:#000; color:#fff; cursor:pointer;">
          Enter Store
        </button>
      {% endform %}
    </div>
  </div>
</section> {% endcomment %}


{{ 'presha-password.css' | asset_url | stylesheet_tag }}
{{ 'presha-password.js' | asset_url | script_tag }}

<section class="presha-page">
  <!-- Announcement bar -->
  <div class="presha-announce">
    Presha Verified Authenticity | Worldwide Shipping | Dubai Based
  </div>

  <!-- Split hero -->
  <div class="presha-split">
    <!-- Left content -->
    <div class="presha-left">
      <div class="presha-left-inner presha-reveal">
        <img class="presha-logo" src="{{ 'logo-full.png' | asset_url }}" alt="Presha Trends" loading="eager" />

        <h1 class="presha-h1">The Dubai Edit is Coming</h1>

        <p class="presha-sub">
          Curated luxury streetwear and rare sneakers, authenticated in Dubai.
        </p>

        <p class="presha-micro">
          Presha Verified • Worldwide Shipping • Premium Support
        </p>

        <!-- Email capture -->
        <div class="presha-form-block">
          {% form 'customer', class: 'presha-newsletter' %}
            <input type="hidden" name="contact[tags]" value="presha-password-page">
            <input type="hidden" name="contact[accepts_marketing]" value="true">

            <input
              class="presha-input"
              type="email"
              name="contact[email]"
              required
              placeholder="Enter your email"
              autocomplete="email"
            />

            <button class="presha-btn" type="submit">
              Get Notified
            </button>
          {% endform %}

          <p class="presha-helper">
            Drops, rare finds, and curated collections, delivered first. No spam.
          </p>
        </div>

        <!-- Password + owner links -->
        <div class="presha-links">
          <button type="button" class="presha-link" data-open-password>
            Enter using password
          </button>

          <span class="presha-sep">|</span>

          <a class="presha-link" href="/admin">
            Store owner? Log in
          </a>
        </div>

        <!-- Trust mini row -->
        <div class="presha-trust">
          <div class="presha-trust-item">Verified</div>
          <div class="presha-trust-item">Secure</div>
          <div class="presha-trust-item">Worldwide</div>
        </div>

        <div class="presha-copy">
          © {{ 'now' | date: '%Y' }} Presha Trends
        </div>
      </div>
    </div>

    <!-- Right image -->
    <div class="presha-right">
      <img
        class="presha-hero-img"
        src="{{ 'luxury-picture.jpg' | asset_url }}"
        alt="Presha Trends"
        loading="eager"
      />
      <div class="presha-overlay" aria-hidden="true"></div>
      <div class="presha-diamond" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Bottom marquee -->
  <div class="presha-marquee" aria-hidden="true">
    <div class="presha-marquee-track">
      <div class="presha-marquee-inner">
        <span>PRESHA TRENDS • COMING SOON • THE DUBAI EDIT • AUTHENTICATED LUXURY • </span>
        <span>PRESHA TRENDS • COMING SOON • THE DUBAI EDIT • AUTHENTICATED LUXURY • </span>
        <span>PRESHA TRENDS • COMING SOON • THE DUBAI EDIT • AUTHENTICATED LUXURY • </span>
        <span>PRESHA TRENDS • COMING SOON • THE DUBAI EDIT • AUTHENTICATED LUXURY • </span>
      </div>
    </div>
  </div>

  <!-- Password modal -->
  <div class="presha-modal" data-password-modal aria-hidden="true">
    <div class="presha-backdrop" data-close-password></div>

    <div class="presha-modal-panel" role="dialog" aria-modal="true" aria-label="Password entry">
      <button class="presha-close" type="button" data-close-password aria-label="Close">
        ×
      </button>

      <h2 class="presha-modal-title">Enter Password</h2>
      <p class="presha-modal-sub">
        Enter the store password to access Presha Trends.
      </p>

      {% form 'storefront_password', class: 'presha-passform' %}
        <input
          class="presha-input"
          type="password"
          name="password"
          required
          placeholder="Password"
          autocomplete="current-password"
        />

        <button class="presha-btn presha-btn-full" type="submit">
          Enter Store
        </button>
      {% endform %}
    </div>
  </div>
</section>