

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {% liquid
    assign total_blocks = section.blocks.size

    # Grid layout calculations
    assign grid_columns = total_blocks | at_most: 4

    # Calculate last row counts using modulo arithmetic
    # last_row_count = (total_blocks - 1) % N + 1
    assign last_row_count = total_blocks | minus: 1 | modulo: 4 | plus: 1
    assign tablet_last_row_count = total_blocks | minus: 1 | modulo: 2 | plus: 1

    # Check if there are orphaned elements (single item in last row)
    assign has_isolated_grid_item_desktop = false
    assign has_isolated_grid_item_tablet = false

    if total_blocks > 4 and last_row_count == 1
      assign has_isolated_grid_item_desktop = true
    endif

    if total_blocks == 5
      assign has_isolated_grid_item_tablet = true
    endif
  %}
  <div
    class="
      footer-content
      spacing-style
      {% if has_isolated_grid_item_desktop %}footer-content--isolated-grid-item-desktop{% endif %}
      {% if has_isolated_grid_item_tablet %}footer-content--isolated-grid-item-tablet{% endif %}
    "
    style="
      {%  render 'spacing-style', settings: section.settings %}
      --footer-gap: {{ section.settings.gap }}px;
      --grid-columns: {{ grid_columns }};
      --last-row-count: {{ last_row_count }};
      --tablet-last-row-count: {{ tablet_last_row_count }};
    "
  >
    {%- comment -%}
      Presha Trends: Custom brand column rendered first with asset-based logo.
      Remaining menu columns render via standard Horizon blocks.
    {%- endcomment -%}

    {%- comment -%} Brand column — logo, tagline, social icon {%- endcomment -%}
    <div class="presha-footer-brand">
      <a href="{{ routes.root_url }}" class="presha-footer-logo-link" aria-label="Presha Trends">
        <img
          src="{{ 'logo-text-white.png' | asset_url }}"
          alt="Presha Trends"
          class="presha-footer-logo"
          width="180"
          height="auto"
          loading="lazy"
        >
      </a>

      <p class="presha-footer-tagline">
        The ultimate destination for authenticated luxury streetwear and rare collectibles. Based in Dubai, shipping worldwide.
      </p>

      {%- comment -%} Social icons row {%- endcomment -%}
      <div class="presha-footer-socials">
        <a
          href="https://www.instagram.com/preshatrends/"
          target="_blank"
          rel="noopener noreferrer"
          class="presha-footer-social-icon"
          aria-label="Instagram"
        >
          {%- comment -%} Instagram icon — matches the circular icon style in Footer.png {%- endcomment -%}
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4.5"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
        </a>
      </div>
    </div>

    {%- comment -%} Menu columns — rendered from footer-group.json blocks, skip brand_col_group {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        <div class="presha-footer-menu-col" {{ block.shopify_attributes }}>
          <p class="presha-footer-menu-heading">{{ block.settings.heading }}</p>
          {%- assign menu = linklists[block.settings.menu] -%}
          {%- if menu != blank -%}
            <ul class="presha-footer-menu-list">
              {%- for link in menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- else -%}
            {%- comment -%} Placeholder links until menus are created in Shopify Admin {%- endcomment -%}
            {%- if block.settings.heading == 'SHOP' -%}
              <ul class="presha-footer-menu-list">
                <li><a href="/collections/new-arrivals">New Arrivals</a></li>
                <li><a href="/collections/sneakers">Sneakers</a></li>
                <li><a href="/collections/apparel">Apparel</a></li>
                <li><a href="/collections/accessories">Accessories</a></li>
                <li><a href="/collections/collectibles">Collectibles</a></li>
              </ul>
            {%- elsif block.settings.heading == 'SUPPORT' -%}
              <ul class="presha-footer-menu-list">
                <li><a href="/pages/authentication">Authentication</a></li>
                <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
                <li><a href="/policies/refund-policy">Returns &amp; Refunds</a></li>
                <li><a href="/pages/track-order">Track Order</a></li>
                <li><a href="/pages/contact">Contact Us</a></li>
              </ul>
            {%- elsif block.settings.heading == 'COMPANY' -%}
              <ul class="presha-footer-menu-list">
                <li><a href="/pages/our-story">Our Story</a></li>
                <li><a href="/blogs/journal">Journal</a></li>
                <li><a href="/pages/careers">Careers</a></li>
                <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
                <li><a href="/policies/terms-of-service">Terms of Service</a></li>
              </ul>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .footer-content {
    contain: content;
    content-visibility: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-gap);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer-content {
      grid-template-columns: repeat(min(var(--grid-columns), 3), 1fr);
      grid-auto-flow: row;
    }

    .footer-content[style*='--grid-columns: 4'] {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-content--isolated-grid-item-tablet > :last-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }

    /* Single item centered */
    .footer-content[style*='--grid-columns: 1'] {
      justify-items: center;
    }

    .footer-content--isolated-grid-item-desktop > :last-child {
      grid-column: 1 / -1;
    }
  }
  /* ── Presha Trends Footer — custom layout to match Footer.png ── */

  /* Dark navy background */
  footer.section-wrapper > .section-background.color-scheme-3,
  footer.section-wrapper > .section.color-scheme-3 {
    background-color: #0f1117;
  }

  /* Override grid: 4 columns — brand (wider) + 3 equal menu cols */
  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: 2fr 1fr 1fr 1fr !important;
      align-items: start;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer-content {
      grid-template-columns: 1fr 1fr !important;
    }
  }

  /* ── Brand column ── */
  .presha-footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .presha-footer-logo-link {
    display: inline-block;
    text-decoration: none;
  }

  .presha-footer-logo {
    width: 180px;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .presha-footer-tagline {
    font-family: 'Jost', sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.65;
    margin: 0;
    max-width: 32ch;
  }

  /* ── Social icons ── */
  .presha-footer-socials {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 4px;
  }

  .presha-footer-social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: border-color 0.22s ease, color 0.22s ease, background 0.22s ease;
    flex-shrink: 0;
  }

  .presha-footer-social-icon:hover {
    border-color: rgba(255, 255, 255, 0.55);
    color: #ffffff;
    background: rgba(255, 255, 255, 0.06);
  }

  .presha-footer-social-icon svg {
    display: block;
  }

  /* ── Menu columns ── */
  .presha-footer-menu-col {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .presha-footer-menu-heading {
    font-family: 'Jost', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 20px;
    padding: 0;
  }

  .presha-footer-menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .presha-footer-menu-list li a {
    font-family: 'Jost', sans-serif;
    font-size: 0.9375rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1;
  }

  .presha-footer-menu-list li a:hover {
    color: #ffffff;
  }

{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    gsap.registerPlugin(ScrollTrigger);

    var footerCols = document.querySelectorAll('.footer-content > *');
    if (!footerCols.length) return;

    gsap.fromTo(
      footerCols,
      { y: 32, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.1,
        ease: 'power3.out',
        clearProps: 'transform,opacity',
        scrollTrigger: {
          trigger: '.footer-content',
          start: 'top 90%',
          once: true
        }
      }
    );
  });
</script>

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "tag": "footer",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "color_scheme": "scheme-1",
        "padding-block-start": 36,
        "padding-block-end": 36
      },
      "blocks": {
        "newsletter-group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 6,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "newsletter-heading": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.join_our_email_list",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3"
              }
            },
            "newsletter-text": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.get_exclusive_deals_and_early_access_to_new_products",
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte"
              }
            }
          },
          "block_order": ["newsletter-heading", "newsletter-text"]
        },
        "newsletter-form": {
          "type": "email-signup",
          "settings": {
            "width": "fill"
          }
        }
      },
      "block_order": ["newsletter-group", "newsletter-form"]
    }
  ]
}
{% endschema %}
