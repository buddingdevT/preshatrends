{% doc %}
  @prompt
    varios brand categories, photo image applied only
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-categories-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-brand-categories-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      margin: 0 auto;
    }
  }

  .ai-brand-categories-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-brand-categories-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 32px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-brand-categories-grid-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.grid_gap }}px;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
  }

  @media screen and (min-width: 750px) {
    .ai-brand-categories-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }

  .ai-brand-category-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-brand-category-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-brand-category-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .ai-brand-category-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-brand-category-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-brand-category-item-{{ ai_gen_id }}:hover .ai-brand-category-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-brand-category-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-brand-category-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-brand-category-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
  }

  .ai-brand-category-title-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
  }

  .ai-brand-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-brand-empty-state-{{ ai_gen_id }} p {
    margin: 0;
    font-size: 14px;
  }
{% endstyle %}

<brand-categories-{{ ai_gen_id }} class="ai-brand-categories-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-categories-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-brand-categories-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% liquid
      assign has_content = false
      for i in (1..6)
        assign image_key = 'category_' | append: i | append: '_image'
        assign title_key = 'category_' | append: i | append: '_title'
        assign link_key = 'category_' | append: i | append: '_link'
        
        assign category_image = block.settings[image_key]
        assign category_title = block.settings[title_key]
        
        if category_image != blank or category_title != blank
          assign has_content = true
          break
        endif
      endfor
    %}

    {% if has_content %}
      <div class="ai-brand-categories-grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign image_key = 'category_' | append: i | append: '_image'
            assign title_key = 'category_' | append: i | append: '_title'
            assign link_key = 'category_' | append: i | append: '_link'
            
            assign category_image = block.settings[image_key]
            assign category_title = block.settings[title_key]
            assign category_link = block.settings[link_key]
          %}

          {% if category_image != blank or category_title != blank %}
            <div class="ai-brand-category-item-{{ ai_gen_id }}">
              <a href="{{ category_link }}" class="ai-brand-category-link-{{ ai_gen_id }}">
                <div class="ai-brand-category-image-wrapper-{{ ai_gen_id }}">
                  {% if category_image != blank %}
                    <img
                      src="{{ category_image | image_url: width: 800 }}"
                      alt="{{ category_image.alt | escape }}"
                      loading="lazy"
                      width="800"
                      height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                      class="ai-brand-category-image-{{ ai_gen_id }}"
                    >
                  {% else %}
                    <div class="ai-brand-category-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                  
                  {% if category_title != blank %}
                    <div class="ai-brand-category-overlay-{{ ai_gen_id }}">
                      <h3 class="ai-brand-category-title-{{ ai_gen_id }}">{{ category_title }}</h3>
                    </div>
                  {% endif %}
                </div>
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-brand-empty-state-{{ ai_gen_id }}">
        <p>Add brand category images and titles to get started</p>
      </div>
    {% endif %}
  </div>
</brand-categories-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandCategories{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('brand-categories-{{ ai_gen_id }}', BrandCategories{{ ai_gen_id }});
  })();
</script>

